# Sentinel Cameroon - Environment Configuration
# Copy this file to .env and adjust values as needed

# For SQLite (Production/Render)
DB_PATH=/var/www/html/database/data/sentinel_cameroon.sqlite

# For MySQL (Development - only used if DB_PATH is not set)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sentinel_cameroon
DB_USER=root
DB_PASS=

# Render deployment indicator
RENDER=false
